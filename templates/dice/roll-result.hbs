<div class="dice-roll" data-action="expandRoll">
    <div class="dice-result">
        <div class="dice-formula">{{title}}</div>
        {{{tooltip}}}
        <div class="dice-formula">{{localize "beryllium.roll.common.total"}} : {{total}}</div>
        <h4 class="dice-total">{{localize "beryllium.roll.common.total"}} : {{totalText}} = {{totalValue}}</h4>
     
        <div class="dice-formula">{{localize "beryllium.RollDifficulte.label"}} : {{seuil}}</div>
        <h4 class="dice-total">{{result}}</h4>

        {{{ fletrineTooltip }}}
        
        {{#if actions}}
        <div class="actions">
            {{#each actions as |action|}}
                <button data-action="{{action.action}}"
                {{#each action.data as |data|}}
                     data-{{data.key}}="{{data.value}}"
                {{/each}}
                >{{action.label}}</button>
            {{/each}}
        </div>
        {{/if}}  
    </div>
</div>
