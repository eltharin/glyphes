            </div>
            <span data-action="addRemoveDeCompetence" data-competence="foi" data-sens="+">+</span>
        </div>
        
        <div class="">
            <label>{{localize "glyphes.competences.social.court"}}</label>
            <span data-action="addRemoveDeCompetence" data-competence="social" data-sens="-">-</span>
            <div class="diceVal">
                <svg width="50" height="50" viewBox="0 0 100 100">
                    <use href="{{ callMethod ValeurDe "getIcon" system.competences.social.value }}"/>
                </svg>
