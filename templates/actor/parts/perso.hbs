                </svg>
                <label>{{ callMethod ValeurDe "getVal" system.competences.constitution.value}}</label>
            </div>
            <span data-action="addRemoveDeCompetence" data-competence="constitution" data-sens="+">+</span>
        </div>

        
    </div>
    
    <div class="competences">
