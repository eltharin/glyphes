                </svg>
                <label>{{ callMethod ValeurDe "getVal" system.competences.esprit.value}}</label>
            </div>
            <span data-action="addRemoveDeCompetence" data-competence="esprit" data-sens="+">+</span>
        </div>

    </div>
</div>

<div>
    Dons <span class="action" data-action="ajoutDon">Ajouter un Don</span>
    {{#each system.donsObj as |don|}}
        <div>
            <label>{{localize (concat "glyphes.dons." don.id ".name")}}</label>
            <span class="action" data-action="supprDon" data-don="{{don.id}}">Supprimer</span>
            <div>{{localize (concat "glyphes.dons." don.id ".description")}}</div>
        </div>
    {{/each}}
</div>


<div>
    heroisme
    <legend>{{localize "glyphes.sheet.actor.heroisme.pts"}}
        <span>
            <span data-action="addRemoveDePts" data-pointtype="heroisme" data-sens="-">-</span>
            <div>{{ fieldOrInput "system.points.heroisme.value" class="pj-sheet-input"}}</div>
            <span data-action="addRemoveDePts" data-pointtype="heroisme" data-sens="+">+</span>
        </span>
    </legend>
</div>



{{> actionHeroique_liste}}


<div data-action="pioche">pioche</div>

{{#each system.sacrificesCards as |card|}}
    <div>{{card.name}}</div>
{{/each}}

</section>