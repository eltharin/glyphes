            <span>
                <span data-action="addRemoveDePts" data-pointtype="ame" data-sens="-">-</span>
                <div>{{ fieldOrInput "system.points.ame.value" class="pj-sheet-input"}}</div>
                <span data-action="addRemoveDePts" data-pointtype="ame" data-sens="+">+</span>
            </span>
        </legend>
        
        <div class="">
            <label>{{localize "glyphes.competences.foi.court"}}</label>
            <span data-action="addRemoveDeCompetence" data-competence="foi" data-sens="-">-</span>
            <div class="diceVal">
                <svg width="50" height="50" viewBox="0 0 100 100">
