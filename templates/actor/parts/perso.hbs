<section>

<div class="col2">
    <div class="competences">
        <legend>{{localize "glyphes.competences.cat.corps"}} 
            <span>
                <span data-action="addRemoveDePts" data-pointtype="corps" data-sens="-">-</span>
                <div>{{ fieldOrInput "system.points.corps.value" class="pj-sheet-input"}}</div>
                <span data-action="addRemoveDePts" data-pointtype="corps" data-sens="+">+</span>
            </span>
        </legend>
        

        <div class="">
            <label>{{localize "glyphes.competences.puissance.court"}}</label>
            <span data-action="addRemoveDeCompetence" data-competence="puissance" data-sens="-">-</span>
            <div class="diceVal">
                <svg width="50" height="50" viewBox="0 0 100 100">
                    <use href="{{ callMethod ValeurDe "getIcon" system.competences.puissance.value }}">
                </svg>
                <label>{{ callMethod ValeurDe "getVal" system.competences.puissance.value}}</label>
            </div>
            <span data-action="addRemoveDeCompetence" data-competence="puissance" data-sens="+">+</span>
        </div>
        
        <div class="">
            <label>{{localize "glyphes.competences.souplesse.court"}}</label>
