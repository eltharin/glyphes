                <svg width="50" height="50" viewBox="0 0 100 100">
                    <use href="{{ callMethod ValeurDe "getIcon" system.competences.souplesse.value }}"/>
                </svg>
                <label>{{ callMethod ValeurDe "getVal" system.competences.souplesse.value}}</label>
            </div>
            <span data-action="addRemoveDeCompetence" data-competence="souplesse" data-sens="+">+</span>
        </div>
        
        <div class="">
