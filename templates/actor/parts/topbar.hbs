
<div class="image">
    <img data-action="editImage" data-edit="img" src="{{document.img}}" alt="Photo de {{document.name}}" />
</div>

<div class="perso">
    <div class="field">
        <label>{{localize "glyphes.sheet.common.nom"}}</label>
        <div>{{ fieldOrInput "name" class="pj-sheet-input" value=document.name}}</div>
    </div>

    <div class="field">
        <label>{{localize "glyphes.sheet.actor.origine"}}</label>
        <div>{{ fieldOrInput "system.origine" class="pj-sheet-input" value=system.origine}}</div>
    </div>

    <div class="field">
        <label>{{localize "glyphes.sheet.actor.race"}}</label>
        <div>
            {{#fieldOrInput "system.race" class="pj-sheet-input"}}
                <select name="system.race">
                    <option value="">{{localize "glyphes.sheet.actor.raceSelect"}}</option>
                    {{#each ../lists.races as |race| }}
                        <option value="{{race.id}}" {{#if (eq race.id ../../system.race) }}selected{{/if}}>{{localize (concat "glyphes.races." race.name) }}</option>
                    {{/each}}
                </select>
            {{/fieldOrInput}}
        </div>
    </div>

</div>


<div class="perso2">
    <div class="blessure field">
        <label>{{localize "glyphes.sheet.actor.combat.blessure"}}</label>
        <div class="points blessure">
            <span class="ptscontrol" data-action="addRemoveDePts" data-pointtype="blessure" data-sens="-">-</span>
            <span class="pts">
                {{#times system.points.blessure.value }}
                    <span class="active"></span>
                {{/times}}
                {{#times system.points.blessure.bonus }}
                    <span class="bonus"></span>
                {{/times}}
                {{#times system.points.blessure.nope }}
                    <span></span>
                {{/times}}
            </span>
            <span class="ptscontrol" data-action="addRemoveDePts" data-pointtype="blessure" data-sens="+">+</span>
        </div>
    </div>
</div>