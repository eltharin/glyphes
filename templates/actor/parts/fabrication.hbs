<section>

    <div>
        <h2>
            <span>{{localize "glyphes.sheet.actor.fabrication.title"}}</span>
            <span class="action add button" data-action="addItem" data-type="fabrication" title="{{localize "glyphes.sheet.actor.fabrication.ajout"}}">{{localize "glyphes.sheet.actor.fabrication.ajoutbtn"}}</span>
        </h2>

        <div class="tabitem">
            {{#each fabrications as |item|}}
                <div class="item fabrication">
                    <div class="lignetab">
                        <label data-action="editItem" data-itemid="{{item.id}}">{{item.name}}</label>
                        <span class="action" >
                            <a data-action="toggle"  data-toggle="item_{{item._id}}"><i class="fas fa-eye"></i></a>
                            <a data-action="deleteItem" data-itemid="{{item.id}}" title="{{localize "glyphes.common.label.delete"}}"><i class="fas fa-trash"></i></a>
                        </span>    
                    </div>
                    
                    <div class="toggleable flexrow" data-toggle_section="item_{{item._id}}">
                        <div class="infos">      
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
    </div>
</section>