            "puissance" : {
                "court" : "PUI",
                "long": "Puissance",
                "description": "La puissance incarne les capacités physiques du personnage. C’est la caractéristique utilisée pour les combats au corps à corps par les créatures qui privilégient la force brute."
            },
            "souplesse" : {
                "court" : "SOU",
                "long": "Souplesse",
                "description": "La souplesse englobe la dextérité, l'agilité générale et la finesse dont le personnage est capable. La souplesse peut être utilisée comme caractéristique de combat si le personnage préfère une approche plus précise (avec des armes légères par exemple) ou à distance."
            },
            "constitution" : {
                "court" : "CON",
                "long": "Constitution",
                "description": "La constitution joue un rôle déterminant dans la capacité du personnage à encaisser les blessures, les empoisonnements, les maladies et tout autre aléa physique et reflète son endurance"
            },
            "foi" : {
                "court" : "FOI",
                "long": "Foi",
                "description": "La foi symbolise l‘engagement du personnage envers des concepts divins qui lui sont chers. Un personnage qui ne dédie pas sa foi à un concept divin peut la consacrer à sa propre personne et la matérialiser sous forme de confiance en soi et de courage. Elle peut être utilisée pour gonfler le moral de ses alliés ou diminuer celui de l'ennemi."
            },
            "social" : {
                "court" : "SOC",
                "long": "Social",
                "description": "Le social reflète les capacités de tromperie, de charme, de persuasion ou de marchandage. Cette caractéristique peut être déterminante pour éviter les combats, ou les précipiter…"
            },
            "esprit" : {
                "court" : "ESP",
                "long": "Esprit",
                "description": "L'esprit représente la capacité intellectuelle du personnage ainsi que la robustesse de son âme. C’est la caractéristique la plus importante des adeptes des arcanes anciennes, matérialisé par des glyphes."
            }
        },
